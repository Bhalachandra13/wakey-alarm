{
  "name": "wakey-frontend",
  "version": "1.0.0",
  "description": "Wakey - Geofence Alarm React Native App",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "build": "eas build --platform all"
  },
  "dependencies": {
    "react": "18.2.0",
    "react-native": "0.73.0",
    "expo": "^50.0.0",
    "expo-location": "^16.5.5",
    "expo-notifications": "^0.26.0",
    "expo-task-manager": "^11.7.0",
    "expo-status-bar": "~1.11.0",
    "expo-splash-screen": "~0.26.0",
    "expo-font": "~11.10.0",
    "react-native-gesture-handler": "~2.14.0",
    "react-native-reanimated": "~3.6.0",
    "react-native-screens": "~3.27.0",
    "react-native-safe-area-context": "4.7.0",
    "react-native-tab-view": "^3.4.0",
    "react-navigation": "^4.4.4",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/bottom-tabs": "^6.5.10",
    "@react-navigation/stack": "^6.3.19",
    "axios": "^1.6.0",
    "zustand": "^4.4.2",
    "react-native-maps": "~1.7.0",
    "@react-native-community/geolocation": "^3.2.1",
    "react-native-stomp-websocket": "^1.0.8",
    "react-native-uuid": "^2.0.0",
    "moment": "^2.29.0",
    "react-native-loading-spinner-overlay": "^3.0.0",
    "react-native-toast-notifications": "^3.2.1"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@types/jest": "^29.5.0",
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.73.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.50.0",
    "jest": "^29.7.0",
    "jest-expo": "^50.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.2.0",
    "expo-dev-client": "^2.4.0"
  },
  "private": true,
  "expo": {
    "name": "Wakey",
    "slug": "wakey-alarm",
    "version": "1.0.0",
    "scheme": "wakey",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTabletMode": true,
      "bundleIdentifier": "com.wakey.alarm"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.wakey.alarm"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Wakey to access your location for geofencing"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#ffffff"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "wakey-alarm-app"
      },
      "API_URL": "http://localhost:8080/api"
    }
  }
}
